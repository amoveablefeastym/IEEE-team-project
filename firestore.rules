// Firestore Security Rules
// Start in test mode for local development, then tighten rules before production.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read to all resources collection, only authenticated users can write
    match /resources/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Example: Questions collection permission - authenticated users can read/write, but you should refine in production
    match /questions/{qid} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users private data
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
